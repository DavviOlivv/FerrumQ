{
  "name": "ferrumq",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.5.2",
  "scripts": {
    "build": "pnpm -r --workspace-concurrency=1 run build",
    "format": "biome format --write .",
    "format:check": "biome format .",
    "lint": "biome lint .",
    "check": "biome check .",
    "check:write": "biome check --write .",
    "test": "pnpm -r --workspace-concurrency=1 run test",
    "typecheck": "pnpm -r --workspace-concurrency=1 run typecheck && pnpm run examples:typecheck",
    "examples:typecheck": "pnpm --filter @ferrumq/sdk run build && tsc -p tsconfig.examples.json --noEmit",
    "ci": "pnpm format:check && pnpm lint && pnpm typecheck && pnpm test && pnpm build"
  },
  "devDependencies": {
    "@ferrumq/sdk": "workspace:*",
    "@biomejs/biome": "2.5.0",
    "@types/node": "^24.10.1",
    "tsup": "^8.5.0",
    "tsx": "^4.20.6",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
