{
  "name": "@ferrumq/sdk",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean",
    "test": "pnpm run build && (test -x ../../target/debug/brokerd || cargo build --manifest-path ../../Cargo.toml -p msg-runtime --bin brokerd) && vitest run",
    "typecheck": "pnpm --filter @ferrumq/protocol run build && tsc --noEmit"
  },
  "dependencies": {
    "@ferrumq/protocol": "workspace:*"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
