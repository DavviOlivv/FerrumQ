{
  "name": "@ferrumq/cli",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "bin": {
    "ferrumq": "./dist/cli.js",
    "msg": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts src/cli.ts --format esm --dts --clean && chmod +x dist/cli.js",
    "test": "vitest run",
    "typecheck": "pnpm --filter @ferrumq/protocol run build && tsc --noEmit"
  },
  "dependencies": {
    "@ferrumq/protocol": "workspace:*",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
