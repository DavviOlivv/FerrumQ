{
  "name": "@ferrumq/protocol",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts --clean && node --input-type=commonjs -e \"const{cpSync,mkdirSync}=require('node:fs');mkdirSync('dist/proto/ferrumq/dataplane/v1',{recursive:true});cpSync('../../crates/msg-protocol/proto/ferrumq/dataplane/v1/dataplane.proto','dist/proto/ferrumq/dataplane/v1/dataplane.proto')\"",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@grpc/grpc-js": "^1.14.0",
    "@grpc/proto-loader": "^0.8.0",
    "zod": "^4.1.12"
  },
  "devDependencies": {
    "tsup": "^8.5.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
